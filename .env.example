# PowerBI Builder environment configuration.
# Copy to ".env" and fill in only what you need. NEVER commit ".env".

# --- Option A: Google (native ADK path, auto-detected) ---
GOOGLE_API_KEY=

# --- Option B: Anthropic / OpenAI via LiteLlm (uncomment ONE, plus LLM_PROVIDER) ---
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=
# LLM_PROVIDER=openai
# OPENAI_API_KEY=

# Runtime paths (defaults shown are usually fine).
OUTPUT_DIR=./output
LOG_LEVEL=INFO
